{
  "name": "mmu-hostel-booking",
  "version": "3.0.0",
  "description": "Mountains of the Moon University – Student Hostel Booking System",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npx serve . --cors --listen 3000",
    "preview": "npx serve . --listen 3000",
    "lint": "npx eslint js/**/*.js",
    "tw:build": "node_modules/.bin/tailwindcss -i ./css/tailwind.input.css -o ./css/tailwind.output.css --minify",
    "tw:watch": "node_modules/.bin/tailwindcss -i ./css/tailwind.input.css -o ./css/tailwind.output.css --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/cli": "^4.2.2",
    "eslint": "^9.39.4",
    "serve": "^14.2.0",
    "tailwindcss": "^4.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mmu",
    "hostel",
    "booking",
    "uganda"
  ],
  "author": "Mountains of the Moon University"
}
